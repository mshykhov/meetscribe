# HuggingFace token for pyannote speaker diarization
# Get it at: https://huggingface.co/settings/tokens
# Accept license at: https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=hf_xxx

# Path to claude CLI (requires Claude Code subscription)
CLAUDE_CLI=claude

# Folder where OBS saves recordings
WATCH_DIR=~/Videos/OBS

# Output folder for processed meetings
OUTPUT_DIR=~/docs/video

# Whisper model size: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=large-v2

# Language (ru, en, etc.) or leave empty for auto-detect
LANGUAGE=

# Max speakers for diarization (0 = auto)
MAX_SPEAKERS=0

# Claude model for summarization
CLAUDE_MODEL=claude-sonnet-4-6
